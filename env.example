# ── Copy this file to .env and fill in your keys ──────────────────────────
# NEVER commit .env to git

# Google Gemini (Google AI Studio — free tier)
GOOGLE_API_KEY=your_google_api_key_here

# LangChain (optional — for tracing)
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=gridlock-hackathon

# Dataset path (update to your local path)
DATA_PATH=data/raw/jan_to_may_police_violation_anonymized.csv
CLEAN_DATA_PATH=data/processed/violations_clean_day1.parquet
